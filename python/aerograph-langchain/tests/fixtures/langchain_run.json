{
  "description": "LangChain to TraceEvent mapping fixtures.",
  "fixtures": [
    {
      "name": "chat_model",
      "input": {
        "run_id": "11111111-1111-1111-1111-111111111111",
        "parent_run_id": null,
        "name": "ChatOpenAI",
        "type": "llm",
        "start": {
          "messages": [[{"content": "Hello", "type": "human"}]]
        },
        "end": {
          "generations": [[{"text": "Hi there!", "message": {"content": "Hi there!", "type": "ai"}}]],
          "llm_output": {"token_usage": {"prompt_tokens": 10, "completion_tokens": 20, "total_tokens": 30}}
        }
      },
      "expected_start": {
        "kind": "prompt",
        "actor": {"kind": "agent", "id": "ChatOpenAI", "name": "ChatOpenAI"},
        "title": "ChatOpenAI",
        "payload": {"text": "Hello"}
      },
      "expected_end": {
        "kind": "response",
        "actor": {"kind": "agent", "id": "ChatOpenAI", "name": "ChatOpenAI"},
        "title": "ChatOpenAI",
        "payload": {"text": "Hi there!"}
      }
    },
    {
      "name": "tool",
      "input": {
        "run_id": "22222222-2222-2222-2222-222222222222",
        "parent_run_id": "11111111-1111-1111-1111-111111111111",
        "name": "SearchTool",
        "type": "tool",
        "start": {
          "serialized": {"name": "SearchTool"},
          "input_str": "query string"
        },
        "end": {
          "output": "Found 5 results"
        }
      },
      "expected_start": {
        "kind": "tool_call",
        "actor": {"kind": "tool", "id": "SearchTool", "name": "SearchTool"},
        "title": "SearchTool",
        "payload": {"input": {"query": "query string"}}
      },
      "expected_end": {
        "kind": "tool_result",
        "actor": {"kind": "tool", "id": "SearchTool", "name": "SearchTool"},
        "title": "SearchTool",
        "payload": {"output": "Found 5 results"}
      }
    },
    {
      "name": "retriever",
      "input": {
        "run_id": "33333333-3333-3333-3333-333333333333",
        "parent_run_id": "11111111-1111-1111-1111-111111111111",
        "name": "VectorStoreRetriever",
        "type": "retriever",
        "start": {
          "query": "search query"
        },
        "end": {
          "documents": [
            {"page_content": "doc1", "metadata": {"source": "test.txt"}}
          ]
        }
      },
      "expected_start": null,
      "expected_end": {
        "kind": "retriever",
        "actor": {"kind": "tool", "id": "VectorStoreRetriever", "name": "VectorStoreRetriever"},
        "title": "VectorStoreRetriever",
        "payload": {
          "query": "search query",
          "documents": [
            {"pageContent": "doc1", "metadata": {"source": "test.txt"}, "score": null}
          ]
        }
      }
    }
  ]
}
