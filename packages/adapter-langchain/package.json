{
  "name": "@aerograph/adapter-langchain",
  "version": "0.2.1",
  "private": false,
  "description": "LangChain adapter for emitting AeroGraph traces from agent workflows.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/SGcpu/AeroGraph.git"
  },
  "bugs": {
    "url": "https://github.com/SGcpu/AeroGraph/issues"
  },
  "homepage": "https://github.com/SGcpu/AeroGraph#readme",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "ai",
    "adapter",
    "langchain",
    "trace",
    "observability"
  ],
  "scripts": {
    "prebuild": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "dependencies": {
    "@aerograph/contracts": "^0.2.0",
    "@aerograph/sdk": "^0.2.0",
    "langchain": "^0.3.0",
    "@langchain/core": "^0.3.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "eslint": "^9.9.0",
    "@eslint/js": "^9.9.0",
    "typescript-eslint": "^8.0.0"
  }
}
